<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">
  <changeSet id="022-1" author="devradar">
    <createTable tableName="engagement_events">
      <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true"/></column>
      <column name="user_id" type="BIGINT"><constraints nullable="false" foreignKeyName="fk_engagement_user" references="users(id)"/></column>
      <column name="radar_id" type="BIGINT"><constraints nullable="false" foreignKeyName="fk_engagement_radar" references="radars(id)"/></column>
      <column name="theme_index" type="INT"><constraints nullable="false"/></column>
      <column name="event_type" type="VARCHAR(32)"><constraints nullable="false"/></column>
      <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/></column>
    </createTable>
    <createIndex indexName="idx_engagement_user_created" tableName="engagement_events">
      <column name="user_id"/>
      <column name="created_at"/>
    </createIndex>
  </changeSet>
</databaseChangeLog>
