<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">
  <changeSet id="025-1" author="devradar">
    <addColumn tableName="engagement_events">
      <column name="theme_id" type="BIGINT">
        <constraints nullable="true"
                     foreignKeyName="fk_engagement_theme"
                     references="radar_themes(id)"/>
      </column>
    </addColumn>
    <createIndex indexName="idx_engagement_theme_id" tableName="engagement_events">
      <column name="theme_id"/>
    </createIndex>
  </changeSet>
</databaseChangeLog>
